{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useTemplate": "off"
      },
      "complexity": {
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      },
      "suspicious": {
        "noRedundantUseStrict": "off",
        "noAssignInExpressions": "off",
        "useIterableCallbackReturn": "off"
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single" },
    "globals": [
      "unsafeWindow",
      "GM",
      "GM_getValue",
      "GM_setValue",
      "GM_deleteValue",
      "GM_listValues",
      "GM_registerMenuCommand",
      "GM_addStyle",
      "GM_xmlhttpRequest",
      "GM_getResourceText",
      "GM_getResourceURL",
      "Toastify"
    ]
  }
}
